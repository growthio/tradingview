//@version=6

// ==================================================================
// OBJECTTIVE: Range Breakout Library - Mark High/Low of a Time Range
//
// The library seperates and uses exposes the function to mark the
// high and low for a defined time range and then the function can be
// used in other indicators, stratigies or in other library.
//
// Check https://github.com/growthio/tradingview for details.
// Check https://in.tradingview.com/u/ZenithClown/ for TV Profile.
// ==================================================================

library("rangeBreakout", overlay = true)

// ------------------------------------------------------------------
// Session Date/Time Parsing Helper Function(s)
// ------------------------------------------------------------------

parseSessionTime(string value, int start) =>
    int startH = int(math.round(str.tonumber(str.substring(
        value, start, start + 2
    ))))
    int startM = int(math.round(str.tonumber(str.substring(
        value, start + 2, start + 4
    ))))

    startH * 60 + startM

// ------------------------------------------------------------------
// Function Implementation: Marks High/Low of a Tracking Window
//
// @param trackTimePeriod - Time range for which the high and low
//  values are tracked. This is the range, any breakout above/below
//  this period can indicate a potential long/short entry condition.
//
// @param drawTimePeriod - Time range for which the range is valid,
//  this is typically from the end of the `trackTimePeriod` to the
//  end of the day (or session) for the security.
//
// @param {*}LineColor - The line color for `high`, `low` and the
//  `mid` line that will be used to plot the values.
//
// @param maxLookbackDays - Number of historic days to retain the
//  range value.
//
// @returns [rangeHi, rangeLo, inTrackRange] - Values to print the
//  range values, and boolean indicator that indicates if the current
//  time is within the tracking time period.
// ------------------------------------------------------------------

export markRange(
    simple string trackTimePeriod
    , simple string drawTimePeriod
    , color highLineColor
    , color lowLineColor
    , color middleLineColor
    , simple int maxLookbackDays = 1
) =>
    tz = syminfo.timezone

    rangeStartTime = parseSessionTime(trackTimePeriod, 0)
    rangeFinalTime = parseSessionTime(trackTimePeriod, 5)
    displayStartTime = parseSessionTime(drawTimePeriod, 0)
    displayFinalTime = parseSessionTime(drawTimePeriod, 5)

    // Check time settings, if not valid return runtime error
    if rangeFinalTime <= rangeStartTime
        runtime.error("Tracking Session end must be after start.")
    if displayFinalTime <= displayStartTime
        runtime.error("Drawing Session end must be after start.")

    // Check if the Current Time in Range/Draw Phase/None
    currentTime = hour(time, tz) * 60 + minute(time, tz)

    inTrackRange = (
        currentTime >= rangeStartTime and currentTime <= rangeFinalTime
    )

    inDrawRange = (
        currentTime >= displayStartTime and currentTime <= displayFinalTime
    )

    // ------------------------------------------------------------------
    // Get the Track Time Period High/Low Range and Reset on Every Day
    // ------------------------------------------------------------------

    newDay = ta.change(time("D")) != 0

    var float rangeHi = na
    var float rangeLo = na

    // Define the calculated lines, then draw them in sequence
    var array<line> hiLines = array.new<line>()
    var array<line> loLines = array.new<line>()

    // Calculate middle line, (high+low)/2 and then draw in sequence
    var array<line> midLines = array.new<line>()

    if newDay
        rangeHi := na
        rangeLo := na

    if inTrackRange
        rangeHi := na(rangeHi) ? high : math.max(rangeHi, high)
        rangeLo := na(rangeLo) ? low  : math.min(rangeLo, low)

    enterDraw = (
        inDrawRange and not inDrawRange[1] and not na(rangeHi) and not na(rangeLo)
    )

    // ------------------------------------------------------------------
    // Visualization of Range High/Low and Session Range Period
    // ------------------------------------------------------------------
    if enterDraw
        newHi = line.new(
            bar_index, rangeHi, bar_index, rangeHi, color = highLineColor
        )
        newLo = line.new(
            bar_index, rangeLo, bar_index, rangeLo, color = lowLineColor
        )

        array.push(hiLines, newHi)
        array.push(loLines, newLo)

        newMid = line.new(
            bar_index, (rangeHi + rangeLo) / 2, bar_index, (rangeHi + rangeLo) / 2, color = middleLineColor
        )

        array.push(midLines, newMid)

        // only keep the latest `maxLookbackDays` of data; else delete
        while array.size(hiLines) > maxLookbackDays
            line.delete(array.shift(hiLines))
            line.delete(array.shift(loLines))
            line.delete(array.shift(midLines))

    if inDrawRange and not enterDraw and array.size(hiLines) > 0 and array.size(loLines) > 0
        curHi = array.last(hiLines)
        curLo = array.last(loLines)

        if not na(curHi)
            line.set_x2(curHi, bar_index)
        if not na(curLo)
            line.set_x2(curLo, bar_index)

        curMid = array.last(midLines)

        if not na(curMid)
            line.set_x2(curMid, bar_index)

    [rangeHi, rangeLo, inTrackRange]
